NODE_ENV=development
API_V2_PORT=8100
API_V2_CORS_ORIGINS=http://localhost:3002
API_V2_RATE_LIMIT_TTL_SECONDS=60
API_V2_RATE_LIMIT_MAX=120
DATABASE_URL=postgresql://appuser:apppassword@localhost:5432/appdb
REDIS_URL=redis://localhost:6379
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:3002
CLERK_JWT_AUDIENCE=
CLERK_WEBHOOK_SIGNING_SECRET=

# Admin Clerk app (separate from customer Clerk app — tresta-admin Clerk application)
ADMIN_CLERK_SECRET_KEY=
ADMIN_CLERK_PUBLISHABLE_KEY=
ADMIN_CLERK_AUTHORIZED_PARTIES=https://admin.tresta.app,http://localhost:3001
ADMIN_CLERK_JWT_AUDIENCE=
RAZORPAY_WEBHOOK_SECRET=
SLACK_WEBHOOK_URL=

# AWS S3 cloud storage
# Region of the S3 bucket (e.g. ap-south-1, us-east-1).
AWS_REGION=
# Bucket that stores all Tresta media + private export artifacts.
AWS_S3_BUCKET=
# IAM access key with s3:PutObject / s3:GetObject / s3:DeleteObject on the bucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional custom endpoint for S3-compatible storage (leave blank to use AWS).
AWS_S3_ENDPOINT=
# Force path-style addressing (true for MinIO / R2; leave false for AWS).
AWS_S3_FORCE_PATH_STYLE=false
# Public read base URL for the "public/" key prefix. CloudFront or
# https://<bucket>.s3.<region>.amazonaws.com — no trailing slash.
S3_PUBLIC_CDN_BASE_URL=
# Max presigned PUT lifetime in seconds (default 600).
S3_PRESIGN_PUT_TTL_SECONDS=600
# Max presigned GET lifetime for private exports in seconds (default 300).
S3_PRESIGN_GET_TTL_SECONDS=300
# Per-upload size caps in bytes; enforced before minting the presigned PUT.
S3_MAX_IMAGE_BYTES=8388608
S3_MAX_VIDEO_BYTES=314572800
S3_MAX_EXPORT_BYTES=104857600
