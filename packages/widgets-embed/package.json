{
  "name": "@workspace/widgets-embed",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/loader.js",
  "types": "./dist/loader.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "devDependencies": {
    "@workspace/typescript-config": "workspace:*",
    "esbuild": "^0.27.0",
    "jsdom": "^26.0.0",
    "typescript": "5.7.3",
    "vitest": "^4.1.4"
  }
}
