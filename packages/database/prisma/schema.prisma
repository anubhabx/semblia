// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  engineType      = "binary"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id // Clerk user Id
  email     String  @unique
  firstName String?
  lastName  String?
  avatar    String? @db.VarChar(1000) // Avatar URL from Azure Blob Storage
  accountDefaultsLogoAssetId String? @unique

  plan                   UserPlan              @default(FREE)
  projects               Project[]
  projectMemberships     ProjectMember[]
  projectInvitesSent     ProjectMemberInvite[] @relation("ProjectMemberInviteInvitedBy")
  projectInvitesAccepted ProjectMemberInvite[] @relation("ProjectMemberInviteAcceptedBy")
  testimonials           Testimonial[]
  apiKeys                ApiKey[]
  subscription           Subscription? // null for free tier users
  subscriptionPayments   SubscriptionPayment[]
  paymentMethods         PaymentMethod[]
  invoices               Invoice[]
  billingProfile         BillingProfile?

  // Notification system relations
  notifications           Notification[]
  notificationPreferences NotificationPreferences?
  organizationsCreated    Organization[]           @relation("OrganizationCreatedBy")
  trustedOriginsCreated   ProjectTrustedOrigin[]   @relation("ProjectTrustedOriginCreatedBy")
  signingSecretsCreated   ProjectSigningSecret[]   @relation("ProjectSigningSecretCreatedBy")
  studioDraftsUpdated     StudioDraft[]            @relation("StudioDraftUpdatedBy")
  integrationConnections  IntegrationConnection[]  @relation("IntegrationConnectionConnectedBy")
  mediaAssets             MediaAsset[]             @relation("MediaAssetUser")
  accountDefaultsLogoAsset MediaAsset?             @relation("UserAccountDefaultsLogoAsset", fields: [accountDefaultsLogoAssetId], references: [id], onDelete: SetNull)

  // Admin tracking
  lastLogin             DateTime?
  onboardingStep        UserOnboardingStep @default(PROFILE)
  onboardingData        Json?
  defaults              Json?
  onboardingCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id              String   @id @default(cuid())
  clerkOrgId      String   @unique @db.VarChar(255)
  name            String   @db.VarChar(255)
  slug            String?  @db.VarChar(255)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User?     @relation("OrganizationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  projects  Project[]

  @@index([slug])
  @@index([createdByUserId])
}

model Project {
  id                     String            @id @default(cuid())
  userId                 String
  organizationId         String?
  name                   String            @db.VarChar(255)
  shortDescription       String?           @db.VarChar(500)
  description            String?           @db.Text
  slug                   String            @unique @db.VarChar(255)
  logoAssetId            String?           @unique
  projectType            ProjectType?      @default(OTHER)
  websiteUrl             String?           @db.VarChar(1000)
  collectionFormUrl      String?           @db.VarChar(1000)
  brandColorPrimary      String?           @db.VarChar(7) // Hex color code
  brandColorSecondary    String?           @db.VarChar(7) // Hex color code
  socialLinks            Json? // { twitter: "...", linkedin: "...", github: "..." }
  tags                   String[] // Array of tags for internal categorization
  allowedOrigins         String[]          @default([])
  visibility             ProjectVisibility @default(PRIVATE)
  isActive               Boolean           @default(true)
  signingSecretEncrypted String?
  signingSecretRotatedAt DateTime?

  // Auto-Moderation Settings
  autoModeration       Boolean @default(true) // Enable auto-moderation
  autoApproveVerified  Boolean @default(false) // Auto-approve verified users
  profanityFilterLevel String? @default("MODERATE") // STRICT, MODERATE, LENIENT
  moderationSettings   Json? // Custom moderation rules

  // Collection Form Configuration
  // {
  //   headerTitle,
  //   headerDescription,
  //   thankYouMessage,
  //   enableRating,
  //   enableJobTitle,
  //   enableCompany,
  //   enableAvatar,
  //   enableVideoUrl,
  //   enableGoogleVerification,
  //   requireRating,
  //   requireJobTitle,
  //   requireCompany,
  //   requireAvatar,
  //   requireVideoUrl,
  //   requireGoogleVerification,
  //   allowAnonymousSubmissions,
  //   notifyOnSubmission
  // }
  formConfig Json?

  testimonials                Testimonial[]
  widgets                     Widget[]
  members                     ProjectMember[]
  memberInvites               ProjectMemberInvite[]
  publicSubmitIdempotencies   PublicSubmitIdempotency[]
  collectionForms             CollectionForm[]
  apiKeys                     ApiKey[]
  formImpressions             FormImpression[]
  testimonialImpressions      TestimonialImpression[]
  trustedOrigins              ProjectTrustedOrigin[]
  signingSecrets              ProjectSigningSecret[]
  publicSurfaceHosts          PublicSurfaceHost[]
  collectionFormSubmissions   CollectionFormSubmission[]
  studioDrafts                StudioDraft[]
  analyticsDaily              ProjectAnalyticsDaily[]
  submissionAnnotations       CollectionFormSubmissionAnnotation[]
  testimonialDisplayRevisions TestimonialDisplayRevision[]
  actionAudits                ProjectActionAudit[]
  outboundWebhookEndpoints    OutboundWebhookEndpoint[]
  outboundWebhookDeliveries   OutboundWebhookDelivery[]
  exportDestinations          ExportDestination[]
  exportRules                 ExportRule[]
  exportDeliveries            ExportDelivery[]
  integrationConnections      IntegrationConnection[]
  mediaAssets                 MediaAsset[] @relation("MediaAssetProject")
  submissionModerationRuns    SubmissionModerationRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logoAsset    MediaAsset?   @relation("ProjectLogoAsset", fields: [logoAssetId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([visibility])
  @@index([projectType])
}

model ProjectMember {
  id        String     @id @default(cuid())
  projectId String
  userId    String
  role      MemberRole
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ProjectMemberInvite {
  id               String                    @id @default(cuid())
  projectId        String
  email            String                    @db.VarChar(320)
  role             MemberRole
  status           ProjectMemberInviteStatus @default(PENDING)
  invitedByUserId  String?
  acceptedByUserId String?
  acceptedAt       DateTime?
  expiresAt        DateTime                  @default(dbgenerated("(now() + interval '14 days')"))
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invitedBy  User?   @relation("ProjectMemberInviteInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  acceptedBy User?   @relation("ProjectMemberInviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@unique([projectId, email], map: "ProjectMemberInvite_pending_project_email_key", where: raw("\"status\" = 'PENDING'::\"ProjectMemberInviteStatus\""))
  @@index([email, status])
  @@index([projectId])
  @@index([invitedByUserId])
  @@index([acceptedByUserId])
}

enum ProjectMemberInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum TrustedOriginKind {
  COLLECTION
  WALL
  CUSTOM
}

enum PublicTrustStatus {
  ACTIVE
  DISABLED
  REVOKED
}

model ProjectTrustedOrigin {
  id              String            @id @default(cuid())
  projectId       String
  origin          String            @db.VarChar(1000)
  kind            TrustedOriginKind @default(CUSTOM)
  status          PublicTrustStatus @default(ACTIVE)
  verifiedAt      DateTime?
  createdByUserId String?
  notes           String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  project     Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User?                      @relation("ProjectTrustedOriginCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  submissions CollectionFormSubmission[]

  @@unique([projectId, origin])
  @@index([projectId, status])
  @@index([projectId, kind, status])
  @@index([createdByUserId])
}

enum ProjectSigningSecretStatus {
  ACTIVE
  REVOKED
}

model ProjectSigningSecret {
  id                 String                     @id @default(cuid())
  projectId          String
  version            Int
  label              String?                    @db.VarChar(120)
  secretEncrypted    String                     @db.Text
  secretHash         String?                    @db.VarChar(128)
  status             ProjectSigningSecretStatus @default(ACTIVE)
  createdByUserId    String?
  rotatedAt          DateTime                   @default(now())
  revokedAt          DateTime?
  lastUsedAt         DateTime?
  lastUsedFromIpHash String?                    @db.VarChar(128)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  project     Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User?                      @relation("ProjectSigningSecretCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  submissions CollectionFormSubmission[]

  @@unique([projectId, version])
  @@index([projectId, status])
  @@index([createdByUserId])
  @@index([lastUsedAt])
}

enum PublicSurfaceFeature {
  COLLECTION
  WALL
}

enum PublicSurfaceResourceType {
  PROJECT
  FORM
  WIDGET
}

enum PublicSurfaceHostStatus {
  ACTIVE
  PENDING_VERIFICATION
  DISABLED
}

enum OutboundWebhookStatus {
  ACTIVE
  DISABLED
  REVOKED
}

enum DeliveryStatus {
  PENDING
  DELIVERING
  SUCCEEDED
  FAILED
  EXHAUSTED
}

enum ExportDestinationProvider {
  CSV
  WEBHOOK
  SLACK
  NOTION
  LINEAR
  GITHUB
}

enum ExportDestinationStatus {
  ACTIVE
  DISABLED
  REVOKED
}

enum IntegrationProvider {
  SLACK
  NOTION
  LINEAR
  GITHUB
}

enum IntegrationAuthStrategy {
  CLERK_OAUTH
  NATIVE_OAUTH
  MANUAL_SECRET
}

model PublicSurfaceHost {
  id                    String                    @id @default(cuid())
  projectId             String
  feature               PublicSurfaceFeature
  resourceType          PublicSurfaceResourceType @default(PROJECT)
  resourceId            String?
  hostname              String                    @unique @db.VarChar(255)
  isDefault             Boolean                   @default(false)
  status                PublicSurfaceHostStatus   @default(ACTIVE)
  verificationTokenHash String?                   @db.VarChar(128)
  verifiedAt            DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, feature, status])
  @@index([resourceType, resourceId])
  @@index([hostname, status])
}

model OutboundWebhookEndpoint {
  id                     String                @id @default(cuid())
  projectId              String
  name                   String                @db.VarChar(255)
  url                    String                @db.VarChar(2000)
  signingSecretEncrypted String                @db.Text
  signingSecretHash      String?               @db.VarChar(128)
  subscribedEvents       String[]              @default([])
  status                 OutboundWebhookStatus @default(ACTIVE)
  lastSuccessAt          DateTime?
  lastFailureAt          DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  project    Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliveries OutboundWebhookDelivery[]

  @@index([projectId, status])
  @@index([projectId, createdAt])
}

model OutboundWebhookDelivery {
  id                  String         @id
  endpointId          String
  projectId           String
  eventType           String         @db.VarChar(120)
  payload             Json
  status              DeliveryStatus @default(PENDING)
  attempts            Int            @default(0)
  nextAttemptAt       DateTime?
  responseStatus      Int?
  responseBodySnippet String?        @db.Text
  error               String?        @db.Text
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  endpoint OutboundWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  project  Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
  @@index([projectId, createdAt])
  @@index([projectId, status, createdAt])
  @@index([eventType, createdAt])
}

model ExportDestination {
  id        String                    @id @default(cuid())
  projectId String
  provider  ExportDestinationProvider
  name      String                    @db.VarChar(255)
  config    Json
  status    ExportDestinationStatus   @default(ACTIVE)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rules      ExportRule[]
  deliveries ExportDelivery[]

  @@index([projectId, provider])
  @@index([projectId, status])
}

model ExportRule {
  id            String   @id @default(cuid())
  projectId     String
  destinationId String
  name          String   @db.VarChar(255)
  eventTypes    String[] @default([])
  filter        Json?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  destination ExportDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  deliveries  ExportDelivery[]

  @@index([projectId, enabled])
  @@index([destinationId])
}

model ExportDelivery {
  id                  String         @id
  projectId           String
  destinationId       String
  ruleId              String?
  eventType           String         @db.VarChar(120)
  payload             Json
  status              DeliveryStatus @default(PENDING)
  attempts            Int            @default(0)
  nextAttemptAt       DateTime?
  error               String?        @db.Text
  artifactAssetId     String?        @unique
  completedAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  destination ExportDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  rule        ExportRule?       @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  artifactAsset MediaAsset?     @relation("ExportArtifactAsset", fields: [artifactAssetId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([projectId, status, createdAt])
  @@index([destinationId, status])
  @@index([ruleId])
  @@index([eventType, createdAt])
}

model IntegrationConnection {
  id                String                  @id @default(cuid())
  projectId         String
  provider          IntegrationProvider
  authStrategy      IntegrationAuthStrategy
  connectedByUserId String?
  clerkProvider     String?                 @db.VarChar(120)
  externalAccountId String?                 @db.VarChar(255)
  status            String                  @default("ACTIVE") @db.VarChar(32)
  scopes            String[]                @default([])
  config            Json?
  lastCheckedAt     DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  connectedBy User?   @relation("IntegrationConnectionConnectedBy", fields: [connectedByUserId], references: [id], onDelete: SetNull)

  @@index([projectId, provider])
  @@index([projectId, status])
  @@index([connectedByUserId])
}

model PublicSubmitIdempotency {
  id                 String              @id @default(cuid())
  projectId          String
  surface            PublicSubmitSurface @default(TESTIMONIALS)
  idempotencyKey     String              @db.VarChar(255)
  payloadHash        String              @db.VarChar(64)
  submissionId       String?
  responseStatusCode Int
  responseBody       Json
  createdAt          DateTime            @default(now())
  expiresAt          DateTime

  project    Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submission CollectionFormSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@unique([projectId, surface, idempotencyKey])
  @@index([submissionId])
  @@index([expiresAt])
}

enum PublicSubmitSurface {
  TESTIMONIALS
  FORM
}

enum MediaAssetPurpose {
  PROJECT_LOGO
  ACCOUNT_DEFAULTS_LOGO
  FORM_BRANDING_LOGO
  TESTIMONIAL_AUTHOR_AVATAR
  TESTIMONIAL_VIDEO
  TESTIMONIAL_MEDIA
  SUBMISSION_ATTACHMENT
  EXPORT_ARTIFACT
}

enum MediaAssetVisibility {
  PUBLIC
  PRIVATE
}

enum MediaAssetStatus {
  PENDING
  ACTIVE
  DELETED
}

model MediaAsset {
  id                 String               @id @default(cuid())
  storageKey         String               @unique @db.VarChar(512)
  bucket             String               @db.VarChar(255)
  contentType        String               @db.VarChar(120)
  byteSize           Int?
  checksumSha256     String?              @db.VarChar(128)
  purpose            MediaAssetPurpose
  visibility         MediaAssetVisibility
  status             MediaAssetStatus     @default(PENDING)
  projectId          String?
  userId             String?
  formId             String?
  submissionId       String?
  createdByActorType String?              @db.VarChar(20)
  createdByActorId   String?              @db.VarChar(64)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  confirmedAt        DateTime?

  project Project?        @relation("MediaAssetProject", fields: [projectId], references: [id], onDelete: Cascade)
  user    User?           @relation("MediaAssetUser", fields: [userId], references: [id], onDelete: Cascade)
  form    CollectionForm? @relation(fields: [formId], references: [id], onDelete: SetNull)
  submission CollectionFormSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  projectLogoFor               Project?        @relation("ProjectLogoAsset")
  accountDefaultsLogoFor       User?           @relation("UserAccountDefaultsLogoAsset")
  testimonialAuthorAvatarFor   Testimonial?    @relation("TestimonialAuthorAvatarAsset")
  testimonialVideoFor          Testimonial?    @relation("TestimonialVideoAsset")
  testimonialMediaFor          Testimonial?    @relation("TestimonialMediaAsset")
  exportArtifactFor            ExportDelivery? @relation("ExportArtifactAsset")
  moderationRuns               SubmissionModerationRun[]

  @@index([projectId, purpose])
  @@index([userId, purpose])
  @@index([status, createdAt])
  @@index([visibility, status])
  @@index([formId])
  @@index([submissionId])
}

model Plan {
  id             String   @id @default(cuid())
  name           String   @db.VarChar(255) // e.g., "Pro Plan", "Starter"
  description    String?  @db.Text
  price          Int // Amount in smallest currency unit (e.g., paise)
  currency       String   @default("INR") @db.VarChar(3)
  interval       String // "month", "year"
  isActive       Boolean  @default(true)
  limits         Json // { "projects": 5, "teamMembers": 2 }
  razorpayPlanId String?  @unique // ID from Razorpay
  type           UserPlan @unique @default(FREE) // Mapping to enum for code compatibility

  subscriptions        Subscription[]
  scheduledSubscriptions Subscription[] @relation("ScheduledPlan")
  subscriptionPayments SubscriptionPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model AdminUser {
  id             String    @id @default(cuid())
  clerkUserId    String    @unique
  email          String    @unique
  isActive       Boolean   @default(true)
  grantedByEmail String?
  grantedAt      DateTime  @default(now())
  revokedAt      DateTime?
  lastLoginAt    DateTime?
  notes          String?

  auditLogs AdminAuditLog[]

  @@index([isActive])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String   @db.VarChar(64)
  targetType  String?  @db.VarChar(64)
  targetId    String?
  metadata    Json?
  ipAddress   String?  @db.VarChar(64)
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
}

model Subscription {
  id     String             @id @default(cuid())
  userId String             @unique
  status SubscriptionStatus // e.g., "active", "canceled", etc.

  // Mirror of provider lifecycle states (Razorpay)
  // Expected values: created, authenticated, active, pending, halted, paused, cancelled, completed, expired
  providerStatus String? @db.VarChar(32)

  // Relations
  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])
  scheduledPlanId String?
  scheduledPlan   Plan?   @relation("ScheduledPlan", fields: [scheduledPlanId], references: [id])

  // Legacy/Code Enum fallback (optional, but good to keep synced)
  userPlan UserPlan @default(FREE) @map("plan")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  externalSubscriptionId String? @unique // Razorpay Subscription ID
  razorpaySubscriptionId String?
  externalCustomerId     String? // Razorpay Customer ID (optional)
  scheduledRazorpaySubscriptionId String? @unique
  scheduledStartAt                DateTime?

  // Razorpay Specifics
  razorpayOrderId      String?
  razorpayPaymentId    String?
  razorpaySignature    String?
  lastPaymentStatus    String?   @db.VarChar(32)
  lastInvoiceStatus    String?   @db.VarChar(32)
  lastWebhookEventId   String?   @db.VarChar(255)
  lastWebhookEventType String?   @db.VarChar(128)
  lastWebhookAt        DateTime?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)

  // Snapshot of price at time of subscription
  amount   Int? // Amount in smallest currency units
  currency String? @default("INR")
  interval String? // "month", "year"

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments SubscriptionPayment[]

  @@index([userId])
  @@index([userId, externalSubscriptionId])
  @@index([planId])
  @@index([scheduledPlanId])
  @@index([status])
  @@index([providerStatus])
  @@index([lastWebhookAt])
}

model PaymentMethod {
  id              String             @id @default(cuid())
  userId          String
  brand           PaymentMethodBrand
  last4           String             @db.VarChar(4)
  expMonth        Int
  expYear         Int
  isDefault       Boolean            @default(false)
  razorpayTokenId String?            @unique
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
}

enum PaymentMethodBrand {
  VISA
  MASTERCARD
  RUPAY
  AMEX
}

model Invoice {
  id                String        @id @default(cuid())
  userId            String
  number            String        @db.VarChar(120)
  issuedAt          DateTime
  amount            Int
  currency          String        @default("INR") @db.VarChar(3)
  status            InvoiceStatus
  planName          String        @db.VarChar(255)
  razorpayInvoiceId String?       @unique
  downloadUrl       String?       @db.VarChar(1000)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, issuedAt])
  @@index([status])
}

enum InvoiceStatus {
  PAID
  OPEN
  VOID
}

model BillingProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  name       String   @default("") @db.VarChar(255)
  line1      String   @default("") @db.VarChar(500)
  line2      String?  @db.VarChar(500)
  city       String   @default("") @db.VarChar(255)
  state      String   @default("") @db.VarChar(255)
  postalCode String   @default("") @db.VarChar(32)
  country    String   @default("IN") @db.VarChar(2)
  gstin      String?  @db.VarChar(32)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubscriptionPayment {
  id                     String    @id @default(cuid())
  provider               String    @default("razorpay") @db.VarChar(32)
  externalPaymentId      String?   @db.VarChar(64)
  externalInvoiceId      String?   @db.VarChar(64)
  externalSubscriptionId String?   @db.VarChar(64)
  userId                 String
  subscriptionId         String
  planId                 String?
  paymentStatus          String?   @db.VarChar(32)
  invoiceStatus          String?   @db.VarChar(32)
  amount                 Int?
  currency               String?   @db.VarChar(8)
  eventType              String    @db.VarChar(128)
  eventCreatedAt         DateTime?
  paidAt                 DateTime?
  failedAt               DateTime?
  rawSnapshot            Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  plan         Plan?        @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@unique([provider, externalPaymentId])
