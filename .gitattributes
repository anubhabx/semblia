# Normalize all text files to LF in the repo; checkout handles platform conversion.
* text=auto eol=lf

# Explicitly text
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.sh   text eol=lf
*.env* text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.prisma text eol=lf

# Binary — never touch
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
